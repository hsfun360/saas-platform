# Dependency folders
node_modules

# Build output folders
dist
build

# Secrets & credentials (NEVER bake these into the image)
.env
.env.*
src/config/gcs-key.json
*.pem
*.key
# JWT signing keys now come from Secret Manager (env vars JWT_PRIVATE_KEY /
# JWT_PUBLIC_KEY); keep the local dev keys/ dir OUT of the image. `*.pem` above
# only matches root-level files, so the nested keys/*.pem needs this explicit rule.
keys/

# Dev notes / docs / scratch files (not needed at runtime, may contain secrets)
*.md
*.txt

# Git files
.git
.gitignore

# Dev scripts
scripts/

# Log files
npm-debug.log*
